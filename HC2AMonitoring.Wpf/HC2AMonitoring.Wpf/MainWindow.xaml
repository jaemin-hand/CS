<Window x:Class="HC2AMonitoring.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HC2A Monitoring"
        Height="760"
        Width="1280"
        Background="#101318"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#1B1F26"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0 0 0 16"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8E2F3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#101318"/>
            <Setter Property="Foreground" Value="#E7EEFF"/>
            <Setter Property="BorderBrush" Value="#394150"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8 5"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#E7EEFF"/>
            <Setter Property="Background" Value="#273040"/>
            <Setter Property="BorderBrush" Value="#46546A"/>
            <Setter Property="Padding" Value="18 8"/>
            <Setter Property="Height" Value="36"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Navigation -->
        <Border Grid.Column="0" Background="#181C22" BorderBrush="#252B34" BorderThickness="0 0 1 0">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="환경 제어"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 8 0 42"/>

                <StackPanel Grid.Row="1">
                    <Border Background="#2A2F39" CornerRadius="6" Padding="12" Margin="0 0 0 10">
                        <TextBlock Text="개요" FontSize="15" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="이력 조회" FontSize="15" Foreground="#8792A6" Margin="12 14"/>
                    <TextBlock Text="알람" FontSize="15" Foreground="#8792A6" Margin="12 14"/>
                    <TextBlock Text="그래프" FontSize="15" Foreground="#8792A6" Margin="12 14"/>
                    <TextBlock Text="로그" FontSize="15" Foreground="#8792A6" Margin="12 14"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0 0 0 10">
                    <TextBlock Text="설정" FontSize="14" Foreground="#8792A6" Margin="4 10"/>
                    <TextBlock Text="시스템" FontSize="14" Foreground="#8792A6" Margin="4 10"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="96"/>
                <RowDefinition Height="130"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Status -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0 0 0 16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="통신 상태" Foreground="#A7B0C0"/>
                        <TextBlock x:Name="ConnectionStatusTextBlock"
                                   Text="최적"
                                   Foreground="#7BE08A"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="DB 저장 상태" Foreground="#A7B0C0"/>
                        <TextBlock x:Name="DatabaseStatusTextBlock"
                                   Text="확인 중"
                                   Foreground="#7BE08A"
                                   FontSize="28"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="DatabaseCountTextBlock"
                                   Text="저장 0건"
                                   Foreground="#A7B0C0"
                                   Margin="0 4 0 0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="최근 알람" Foreground="#A7B0C0"/>
                        <TextBlock x:Name="LastAlarmTextBlock"
                                   Text="알람 없음"
                                   Foreground="#D8E2F3"
                                   FontSize="16"
                                   Margin="0 10 0 0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Summary Cards -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.4*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0 0 16 16">
                    <StackPanel>
                        <TextBlock Text="현재 온도" Foreground="#A7B0C0"/>
                        <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                            <TextBlock x:Name="CurrentTemperatureTextBlock"
                                       Text="--.-"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="#BFD0F4"/>
                            <TextBlock Text=" °C" FontSize="22" VerticalAlignment="Bottom" Margin="4 0 0 7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0 0 16 16">
                    <StackPanel>
                        <TextBlock Text="상대 습도" Foreground="#A7B0C0"/>
                        <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                            <TextBlock x:Name="CurrentHumidityTextBlock"
                                       Text="--.-"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="#BFD0F4"/>
                            <TextBlock Text=" %" FontSize="22" VerticalAlignment="Bottom" Margin="4 0 0 7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0 0 16 16">
                    <StackPanel>
                        <TextBlock Text="기준 범위 설정" Foreground="#A7B0C0" Margin="0 0 0 10"/>

                        <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                            <TextBlock Text="습도" Width="44" VerticalAlignment="Center"/>
                            <TextBox x:Name="HumidityMinTextBox" Text="30"/>
                            <TextBlock Text="~" Margin="8 0" VerticalAlignment="Center"/>
                            <TextBox x:Name="HumidityMaxTextBox" Text="60"/>
                            <TextBlock Text="%RH" Margin="8 0 0 0" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="온도" Width="44" VerticalAlignment="Center"/>
                            <TextBox x:Name="TemperatureMinTextBox" Text="20"/>
                            <TextBlock Text="~" Margin="8 0" VerticalAlignment="Center"/>
                            <TextBox x:Name="TemperatureMaxTextBox" Text="30"/>
                            <TextBlock Text="°C" Margin="8 0 0 0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Vertical" Width="110">
                    <Button x:Name="StartButton" Content="Start" Margin="0 0 0 10" Click="StartButton_Click"/>
                    <Button x:Name="StopButton" Content="Stop" IsEnabled="False" Click="StopButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Body -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Graph -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0 0 16 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0 0 0 18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="실시간 그래프"
                                           FontSize="22"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="최근 60개 샘플"
                                           Foreground="#8792A6"
                                           Margin="0 6 0 0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0 0 18 0">
                                    <Rectangle Width="18" Height="3" Fill="#6FA8FF" VerticalAlignment="Center"/>
                                    <TextBlock Text="온도" Foreground="#A7B0C0" Margin="8 0 0 0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="18" Height="3" Fill="#7BE08A" VerticalAlignment="Center"/>
                                    <TextBlock Text="습도" Foreground="#A7B0C0" Margin="8 0 0 0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#070B10"
                                BorderBrush="#26384A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0" Margin="0 10 10 28">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="ChartMaxLabelTextBlock"
                                                   Text="--"
                                                   Foreground="#8792A6"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="value"
                                                   Grid.Row="1"
                                                   Foreground="#566173"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ChartMinLabelTextBlock"
                                                   Text="--"
                                                   Grid.Row="2"
                                                   Foreground="#8792A6"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid Grid.Column="1">
                                        <Grid Margin="0 10 0 28">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" BorderBrush="#182230" BorderThickness="0 1 0 0"/>
                                            <Border Grid.Row="1" BorderBrush="#182230" BorderThickness="0 1 0 0"/>
                                            <Border Grid.Row="2" BorderBrush="#182230" BorderThickness="0 1 0 0"/>
                                            <Border Grid.Row="3" BorderBrush="#182230" BorderThickness="0 1 0 1"/>
                                        </Grid>

                                        <Canvas x:Name="ChartCanvas"
                                                Margin="0 10 0 28"
                                                Background="Transparent"
                                                ClipToBounds="True"
                                                SizeChanged="ChartCanvas_SizeChanged"
                                                MouseMove="ChartCanvas_MouseMove"
                                                MouseLeave="ChartCanvas_MouseLeave">
                                            <Polyline x:Name="TemperaturePolyline"
                                                      Stroke="#6FA8FF"
                                                      StrokeThickness="2.5"
                                                      StrokeLineJoin="Round"/>
                                            <Polyline x:Name="HumidityPolyline"
                                                      Stroke="#7BE08A"
                                                      StrokeThickness="2.5"
                                                      StrokeLineJoin="Round"/>
                                            <Line x:Name="ChartHoverLine"
                                                  Y1="0"
                                                  Stroke="#46546A"
                                                  StrokeThickness="1"
                                                  StrokeDashArray="3 3"
                                                  Visibility="Collapsed"/>
                                            <Ellipse x:Name="TemperatureHoverMarker"
                                                     Width="10"
                                                     Height="10"
                                                     Fill="#6FA8FF"
                                                     Stroke="#D8E2F3"
                                                     StrokeThickness="1.5"
                                                     Visibility="Collapsed"/>
                                            <Ellipse x:Name="HumidityHoverMarker"
                                                     Width="10"
                                                     Height="10"
                                                     Fill="#7BE08A"
                                                     Stroke="#D8E2F3"
                                                     StrokeThickness="1.5"
                                                     Visibility="Collapsed"/>
                                            <Border x:Name="ChartTooltipBorder"
                                                    Background="#111821"
                                                    BorderBrush="#46546A"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="10"
                                                    Visibility="Collapsed">
                                                <TextBlock x:Name="ChartTooltipTextBlock"
                                                           Foreground="#E7EEFF"
                                                           FontSize="13"
                                                           LineHeight="20"/>
                                            </Border>
                                        </Canvas>
                                    </Grid>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="1"
                                               Text="old"
                                               Foreground="#566173"/>
                                    <TextBlock Grid.Column="2"
                                               x:Name="ChartLatestTimeTextBlock"
                                               Text="waiting"
                                               Foreground="#8792A6"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <!-- Right Panel -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.1*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0 0 0 16">
                        <StackPanel>
                            <TextBlock Text="실시간 센서 피드"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Margin="0 0 0 18"/>

                            <!-- Sensor grid CH1 only -->
                            <Border Background="#0D1117" CornerRadius="6" Padding="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <TextBlock Text="CH1"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"/>
                                        <StackPanel Orientation="Horizontal" Margin="0 10 0 0">
                                            <TextBlock Text="--.-"
                                                       x:Name="FeedTemperatureTextBlock"
                                                       FontSize="28"
                                                       Foreground="#BFD0F4"/>
                                            <TextBlock Text=" °C" VerticalAlignment="Bottom" Margin="4 0 0 5"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="--.-"
                                                       x:Name="FeedHumidityTextBlock"
                                                       FontSize="20"
                                                       Foreground="#BFD0F4"/>
                                            <TextBlock Text=" %RH" VerticalAlignment="Bottom" Margin="4 0 0 3"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1"
                                               x:Name="FeedStatusTextBlock"
                                               Text="정상"
                                               Foreground="#7BE08A"
                                               VerticalAlignment="Top"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="이벤트 로그"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Margin="0 0 0 18"/>

                            <TextBlock x:Name="AlarmTextBlock"
                                       Text="알람 없음"
                                       Foreground="#7BE08A"
                                       FontSize="16"
                                       Margin="0 0 0 16"/>

                            <TextBlock Text="Raw Response"
                                       Foreground="#A7B0C0"
                                       Margin="0 0 0 6"/>

                            <TextBox x:Name="RawResponseTextBox"
                                     Height="110"
                                     Width="Auto"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     Text=""/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
